{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "types": ["node", "jest"],
    "sourceMap": true,
    "outDir": "./dist",
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "example", "**/node_modules/*"]
}
